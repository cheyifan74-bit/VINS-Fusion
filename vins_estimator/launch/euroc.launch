<launch>
    <!-- VINS-Fusion stereo + IMU for EuRoC dataset -->
    <node name="vins_estimator" pkg="vins" type="vins_node" 
          args="$(find vins)/../config/euroc/euroc_stereo_imu_config.yaml"
          output="screen" />

    <!-- Loop fusion (optional) -->
    <!-- <node name="loop_fusion" pkg="loop_fusion" type="loop_fusion_node" 
          args="$(find vins)/../config/euroc/euroc_stereo_imu_config.yaml"
          output="screen" /> -->

    <!-- RViz -->
    <node name="rviz" pkg="rviz" type="rviz" 
          args="-d $(find vins)/../config/vins_rviz_config.rviz" 
          output="log" />
</launch>
